{
  "name": "radio-rucphen-theme",
  "version": "0.1.0",
  "private": true,
  "description": "Build pipeline voor Radio Rucphen WordPress block theme (Tailwind CSS 4.x).",
  "scripts": {
    "dev:css": "npx @tailwindcss/cli -i ./src/css/app.css -o ./assets/css/app.css --watch",
    "build:css": "npx @tailwindcss/cli -i ./src/css/app.css -o ./assets/css/app.css --minify",
    "dev:js": "esbuild src/js/app.js --bundle --outfile=assets/js/app.js --watch",
    "build:js": "esbuild src/js/app.js --bundle --minify --outfile=assets/js/app.js",
    "build": "npm run build:css && npm run build:js"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4",
    "tailwindcss": "^4",
    "esbuild": "^0.23.0"
  }
}
