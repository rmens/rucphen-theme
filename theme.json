{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "useRootPaddingAwareAlignments": true,
        "layout": {
            "contentSize": "1200px",
            "wideSize": "1440px"
        },
        "color": {
            "background": true,
            "text": true,
            "link": true,
            "custom": true,
            "customDuotone": false,
            "defaultPalette": false,
            "defaultGradients": false,
            "palette": [
                { "slug": "brand", "color": "#003576", "name": "Brand" },
                { "slug": "brand-dark", "color": "#00254F", "name": "Brand donker" },
                { "slug": "accent", "color": "#FFDE00", "name": "Accent" },
                { "slug": "cyan", "color": "#00A7DF", "name": "Cyan" },
                { "slug": "ink", "color": "#0F172A", "name": "Inkt" },
                { "slug": "surface", "color": "#F8FAFC", "name": "Oppervlak" },
                { "slug": "white", "color": "#FFFFFF", "name": "Wit" },
                { "slug": "muted", "color": "#64748B", "name": "Gedempt" }
            ]
        },
        "typography": {
            "customFontSize": true,
            "fontWeight": true,
            "lineHeight": true,
            "dropCap": false,
            "fontSizes": [
                { "slug": "small", "size": "0.875rem", "name": "Klein" },
                { "slug": "medium", "size": "1.0625rem", "name": "Middel" },
                { "slug": "large", "size": "1.25rem", "name": "Groot" },
                { "slug": "x-large", "size": "1.75rem", "name": "Extra groot" },
                { "slug": "xx-large", "size": "2.5rem", "name": "Display" }
            ],
            "fontFamilies": [
                {
                    "slug": "system",
                    "name": "Systeem",
                    "fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif"
                },
                {
                    "slug": "display",
                    "name": "Display",
                    "fontFamily": "\"Inter\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif"
                }
            ]
        },
        "spacing": {
            "spacingScale": {
                "operator": "*",
                "increment": 1.5,
                "steps": 7,
                "mediumStep": 1.5,
                "unit": "rem"
            },
            "units": ["px", "em", "rem", "%", "vw", "vh"]
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--surface)",
            "text": "var(--wp--preset--color--ink)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--system)",
            "fontSize": "1.0625rem",
            "lineHeight": "1.6"
        },
        "elements": {
            "link": {
                "color": { "text": "var(--wp--preset--color--brand)" },
                ":hover": { "color": { "text": "var(--wp--preset--color--brand-dark)" } }
            },
            "h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--display)", "fontWeight": "700", "lineHeight": "1.2" } },
            "h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--display)", "fontWeight": "700", "lineHeight": "1.25" } },
            "h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--display)", "fontWeight": "600", "lineHeight": "1.3" } },
            "button": {
                "color": {
                    "background": "var(--wp--preset--color--brand)",
                    "text": "var(--wp--preset--color--white)"
                },
                "border": { "radius": "6px" },
                ":hover": {
                    "color": {
                        "background": "var(--wp--preset--color--brand-dark)",
                        "text": "var(--wp--preset--color--white)"
                    }
                }
            }
        }
    },
    "customTemplates": [
        { "name": "page-nieuws", "title": "Nieuwsoverzicht", "postTypes": ["page"] },
        { "name": "page-video", "title": "Video-overzicht", "postTypes": ["page"] }
    ],
    "templateParts": [
        { "name": "header", "title": "Header", "area": "header" },
        { "name": "footer", "title": "Footer", "area": "footer" },
        { "name": "sticky-player", "title": "Sticky player", "area": "uncategorized" },
        { "name": "mobile-menu", "title": "Mobiel menu", "area": "uncategorized" },
        { "name": "search-overlay", "title": "Zoek-overlay", "area": "uncategorized" }
    ]
}
