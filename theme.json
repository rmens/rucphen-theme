{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "useRootPaddingAwareAlignments": true,
        "layout": {
            "contentSize": "1200px",
            "wideSize": "1440px"
        },
        "color": {
            "background": true,
            "text": true,
            "link": true,
            "custom": true,
            "customDuotone": false,
            "defaultPalette": false,
            "defaultGradients": false,
            "palette": [
                { "slug": "brand", "color": "#003576", "name": "Brand" },
                { "slug": "brand-dark", "color": "#00254F", "name": "Brand donker" },
                { "slug": "accent", "color": "#FFDE00", "name": "Accent geel" },
                { "slug": "cyan", "color": "#00A7DF", "name": "Cyan" },
                { "slug": "ink", "color": "#0F172A", "name": "Inkt" },
                { "slug": "ink-soft", "color": "#475569", "name": "Inkt zacht" },
                { "slug": "surface", "color": "#F8FAFC", "name": "Oppervlak" },
                { "slug": "bg-app", "color": "#F4F7FB", "name": "Pagina achtergrond" },
                { "slug": "line", "color": "#E2E8F0", "name": "Lijn" },
                { "slug": "white", "color": "#FFFFFF", "name": "Wit" },
                { "slug": "muted", "color": "#64748B", "name": "Gedempt" }
            ]
        },
        "typography": {
            "customFontSize": true,
            "fontWeight": true,
            "lineHeight": true,
            "dropCap": false,
            "fontSizes": [
                { "slug": "small", "size": "0.875rem", "name": "Klein" },
                { "slug": "medium", "size": "1.0625rem", "name": "Middel" },
                { "slug": "large", "size": "1.25rem", "name": "Groot" },
                { "slug": "x-large", "size": "1.75rem", "name": "Extra groot" },
                { "slug": "xx-large", "size": "2.5rem", "name": "Display" }
            ],
            "fontFamilies": [
                {
                    "slug": "sans",
                    "name": "Inter",
                    "fontFamily": "\"Inter\", \"Helvetica Neue\", Arial, sans-serif"
                },
                {
                    "slug": "display",
                    "name": "Bricolage Grotesque",
                    "fontFamily": "\"Bricolage Grotesque\", \"Inter\", \"Helvetica Neue\", Arial, sans-serif"
                }
            ]
        },
        "spacing": {
            "spacingScale": {
                "operator": "*",
                "increment": 1.5,
                "steps": 7,
                "mediumStep": 1.5,
                "unit": "rem"
            },
            "units": ["px", "em", "rem", "%", "vw", "vh"]
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        }
        },
        "styles": {
        "color": {
            "background": "var(--wp--preset--color--bg-app)",
            "text": "var(--wp--preset--color--ink)"
        },
        "spacing": {
            "blockGap": "0",
            "padding": {
                "bottom": "calc(var(--player-height) + env(safe-area-inset-bottom))"
            }
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--sans)",
            "fontSize": "1.0625rem",
            "lineHeight": "1.6"
        },
        "elements": {
            "link": {
                "typography": { "textDecoration": "none" }
            },
            "h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--display)", "fontWeight": "800", "lineHeight": "1.1" } },
            "h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--display)", "fontWeight": "800", "lineHeight": "1.15" } },
            "h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--display)", "fontWeight": "700", "lineHeight": "1.2" } },
            "button": {
                "color": {
                    "background": "var(--wp--preset--color--brand)",
                    "text": "var(--wp--preset--color--white)"
                },
                "border": { "radius": "6px" },
                ":hover": {
                    "color": {
                        "background": "var(--wp--preset--color--brand-dark)",
                        "text": "var(--wp--preset--color--white)"
                    }
                }
            }
        }
    },
    "customTemplates": [
        { "name": "page-hero", "title": "Hero-pagina", "postTypes": ["page"] },
        { "name": "page-plain", "title": "Plain-pagina", "postTypes": ["page"] }
    ],
    "templateParts": [
        { "name": "header", "title": "Header", "area": "header" },
        { "name": "footer", "title": "Footer", "area": "footer" },
        { "name": "sticky-player", "title": "Sticky player", "area": "uncategorized" },
        { "name": "site-end", "title": "Site einde", "area": "uncategorized" },
        { "name": "front-page-content", "title": "Homepage inhoud", "area": "uncategorized" },
        { "name": "program-archive-content", "title": "Programmagids inhoud", "area": "uncategorized" },
        { "name": "program-single-content", "title": "Programma detail inhoud", "area": "uncategorized" },
        { "name": "presenter-archive-content", "title": "Presentatoren inhoud", "area": "uncategorized" },
        { "name": "presenter-single-content", "title": "Presentator detail inhoud", "area": "uncategorized" },
        { "name": "podcast-archive-content", "title": "Podcast archief inhoud", "area": "uncategorized" },
        { "name": "podcast-single-content", "title": "Podcast detail inhoud", "area": "uncategorized" },
        { "name": "news-archive-content", "title": "Nieuws archief inhoud", "area": "uncategorized" },
        { "name": "events-archive-content", "title": "Agenda archief inhoud", "area": "uncategorized" },
        { "name": "page-content", "title": "Standaard pagina inhoud", "area": "uncategorized" },
        { "name": "page-plain-content", "title": "Plain pagina inhoud", "area": "uncategorized" },
        { "name": "single-content", "title": "Standaard artikel inhoud", "area": "uncategorized" },
        { "name": "archive-content", "title": "Standaard archief inhoud", "area": "uncategorized" },
        { "name": "search-content", "title": "Zoekresultaten inhoud", "area": "uncategorized" },
        { "name": "index-content", "title": "Index inhoud", "area": "uncategorized" },
        { "name": "not-found-content", "title": "404 inhoud", "area": "uncategorized" }
    ]
}
